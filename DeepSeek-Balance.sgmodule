#!name=DeepSeek 余额查询
#!desc=定时查询 DeepSeek API 余额，面板展示 + 低余额通知。需填入 API Key（从 platform.deepseek.com/api_keys 获取）
#!arguments=API_KEY=sk-...&LOW_THRESHOLD=5

[Script]
DeepSeek-Balance-Cron = type=cron, cronexp="0 */6 * * *", script-path=deepseek-balance.js, argument=api_key=%API_KEY%&threshold=%LOW_THRESHOLD%
DeepSeek-Balance-Panel = type=generic, script-path=deepseek-panel.js, argument=api_key=%API_KEY%&threshold=%LOW_THRESHOLD%

[Panel]
💎 DeepSeek 余额 = script-name=DeepSeek-Balance-Panel, update-interval=3600

[MITM]
; 无需 MITM，脚本通过 $httpClient 直连 API
